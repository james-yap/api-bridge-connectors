# Local bootstrap config for the Actual Budget connector.
# Prefer a secret manager for real use. If you copy this to `.env`, keep it
# gitignored and private.

# Actual server URL.
# For the local server run by the Actual desktop app, this is usually:
ACTUAL_SERVER_URL=http://localhost:5006

# Budget Sync ID.
# In Actual: open the budget, go to Settings -> Show advanced settings, then
# copy the Sync ID.
ACTUAL_SYNC_ID=00000000-0000-0000-0000-000000000000

# Server password.
# This is the password used to sign in to your Actual server. For local-only
# bootstrap you can put it here; for regular automation, inject it with
# 1Password CLI or another secret manager.
ACTUAL_PASSWORD=

# Uncomment only if this budget uses Actual end-to-end encryption.
# This is the budget encryption password, not the server login password.
# ACTUAL_ENCRYPTION_PASSWORD=
